## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Rider
.idea/
*.sln.iml

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# NuGet
*.nupkg
*.snupkg

# dotnet
project.lock.json
project.fragment.lock.json
artifacts/

# .NET Core
*.dll
*.exe
*.so
*.dylib

# Environment variables
.env
.env.local
appsettings.Development.json

# OS
.DS_Store
Thumbs.db
